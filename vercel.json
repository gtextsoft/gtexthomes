{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/payment",
      "destination": "https://zfrmz.com/tSR5t8A8dl6abBqOGBTh",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
